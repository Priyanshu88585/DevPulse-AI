# GitHub Contributions — Environment Variables
# Copy this file to .env and fill in your values

# GitHub Personal Access Token (required for pushing commits via Actions)
GITHUB_TOKEN=

# Git Configuration
GIT_USER_NAME=GitHub Contributions Bot
GIT_USER_EMAIL=bot@github-contributions.dev

# Environment
NODE_ENV=production

# Timezone (IANA format)
TZ=UTC

# Enable/disable auto-commit after generation
AUTO_COMMIT=true

# Enable/disable auto-push after commit
AUTO_PUSH=true
